#!/bin/bash
#SBATCH --job-name=hera_v2_eval_verbose
#SBATCH --partition=gpu_a100
#SBATCH --time=06:00:00
#SBATCH --gpus=1
#SBATCH --cpus-per-task=18
#SBATCH --mem=180G
#SBATCH --output=/projects/prjs1800/jobs/output/%j_hera_v2_eval_verbose.log
set -eo pipefail

module purge
module load 2025
module load Anaconda3/2025.06-1
module load CUDA/12.8.0

set -a
. /projects/prjs1800/.env
set +a
export OPENAI_API_KEY="${OPENAI_API_KEY:-${OPENAI_API_KEY_PRIVATE:-}}"
export PYTHONNOUSERSITE=1
export HF_HOME=${HF_HOME:-/projects/prjs1800/.cache/huggingface}
export TRANSFORMERS_CACHE=${TRANSFORMERS_CACHE:-$HF_HOME}
export HF_HUB_CACHE=${HF_HUB_CACHE:-$HF_HOME/hub}
export HF_TOKEN="${HF_TOKEN:-${HF_API_KEY:-}}"

source /projects/prjs1800/venvs/FlashRAG-venv/bin/activate

HERA_DIR=/projects/prjs1800/hera
INDEX_PATH=/projects/prjs1800/datasets/flashrag/indexes/e5_Flat.index
CORPUS_PATH=/projects/prjs1800/datasets/flashrag/retrieval-corpus/wiki18_100w.jsonl

cd $HERA_DIR
export PYTHONPATH=$HERA_DIR/src

# ---------- generate seed (non-evolved) prompts file ----------
python -c "
from hera.agents import load_seed_prompts, save_prompts
save_prompts(load_seed_prompts(), 'exp_lib/run02_seed/prompts.json')
print('seed prompts written')
"
# Copy library over so seed eval uses v2 evolved insights with seed prompts.
cp exp_lib/run02/library.json exp_lib/run02_seed/library.json

# ---------- launch retriever ----------
RETR_PORT=8003
echo "[retriever] launching ..."
python scripts/snellius_retriever_server.py \
  --index-path $INDEX_PATH \
  --corpus-path $CORPUS_PATH \
  --encoder intfloat/e5-base-v2 \
  --host 127.0.0.1 \
  --port $RETR_PORT \
  --device cuda > $HERA_DIR/logs/retriever_verbose_$RETR_PORT.log 2>&1 &
RETR_PID=$!

# ---------- launch vLLM Qwen3-14B ----------
VLLM_PORT=8001
echo "[vllm] launching Qwen3-14B on port $VLLM_PORT ..."
python -m vllm.entrypoints.openai.api_server \
  --model Qwen/Qwen3-14B \
  --host 127.0.0.1 \
  --port $VLLM_PORT \
  --dtype auto \
  --max-model-len 8192 \
  --gpu-memory-utilization 0.85 \
  --trust-remote-code > $HERA_DIR/logs/vllm_verbose_$VLLM_PORT.log 2>&1 &
VLLM_PID=$!
trap "kill ${RETR_PID:-} ${VLLM_PID:-} 2>/dev/null || true" EXIT

for i in $(seq 1 600); do curl -sf http://127.0.0.1:$RETR_PORT/health >/dev/null 2>&1 && break; sleep 5; done
echo "[retriever] ready"
for i in $(seq 1 600); do curl -sf http://127.0.0.1:$VLLM_PORT/v1/models >/dev/null 2>&1 && break; sleep 5; done
echo "[vllm] ready"

export HERA_VLLM_ENDPOINTS="http://127.0.0.1:$VLLM_PORT/v1"
export HERA_RETRIEVER_URL="http://127.0.0.1:$RETR_PORT/retrieve"
export HERA_TEST_DIR=/projects/prjs1800/hera/data
export HERA_BAMBOOGLE_DIR=/projects/prjs1800/hera/data/bamboogle
export HERA_ANNOTATIONS_DIR=/projects/prjs1800/hera/data/annotations
export HERA_PYTHON=/projects/prjs1800/venvs/FlashRAG-venv/bin/python
# Disable post-process span normalizer → keep raw verbose answers.
export HERA_DISABLE_SPAN_NORMALIZE=1

echo "[eval] starting all 4 datasets with seed (verbose) prompts + v2 library ..."
bash scripts/run_all_eval.sh exp_lib/run02_seed results/run02_eval_verbose 1000 2>&1 | tee $HERA_DIR/logs/eval_master_v2_verbose.log

echo "[aggregate]"
python scripts/aggregate_results.py --out-dir results/run02_eval_verbose | tee $HERA_DIR/logs/aggregate_v2_verbose.log

echo "=== HERA v2 VERBOSE EVAL DONE ==="
